{
  "openapi": "3.0.3",
  "info": {
    "title": "Atuin Sync Server API",
    "description": "HTTP API for the atuin sync server (crates/atuin-server). Schemas are derived from the Rust types in atuin-common, so they mirror their serde output exactly. All error responses use the ErrorResponse shape {\"reason\": string}. Every response carries an `Atuin-Version` header with the server's cargo version; the client uses it to refuse syncing across major versions. If the server is configured with a URL path prefix, it must be included in the client base URL.",
    "contact": {
      "name": "Ellie Huxtable",
      "email": "ellie@atuin.sh"
    },
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "handlers"
        ],
        "operationId": "index",
        "responses": {
          "200": {
            "description": "Server homage and version",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexResponse"
                }
              }
            }
          }
        }
      }
    },
    "/account": {
      "delete": {
        "tags": [
          "handlers::user"
        ],
        "operationId": "delete_account",
        "responses": {
          "200": {
            "description": "Account deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteUserResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "session": []
          }
        ]
      }
    },
    "/account/password": {
      "patch": {
        "tags": [
          "handlers::user"
        ],
        "operationId": "change_password",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Password changed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangePasswordResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Not authenticated, or current password incorrect",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "session": []
          }
        ]
      }
    },
    "/api/v0/me": {
      "get": {
        "tags": [
          "handlers::v0::me"
        ],
        "operationId": "me",
        "responses": {
          "200": {
            "description": "The authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "session": []
          }
        ]
      }
    },
    "/api/v0/record": {
      "get": {
        "tags": [
          "handlers::v0::record"
        ],
        "operationId": "record_status",
        "responses": {
          "200": {
            "description": "Max record index per host and tag",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordStatus"
                }
              }
            }
          },
          "4XX": {
            "description": "Not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "session": []
          }
        ]
      },
      "post": {
        "tags": [
          "handlers::v0::record"
        ],
        "operationId": "post_records",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/RecordEncrypted"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Records stored (empty body)"
          },
          "4XX": {
            "description": "Not authenticated, or a record was too large",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "session": []
          }
        ]
      }
    },
    "/api/v0/record/next": {
      "get": {
        "tags": [
          "handlers::v0::record"
        ],
        "operationId": "next_records",
        "parameters": [
          {
            "name": "host",
            "in": "query",
            "description": "Host ID (hyphenated lowercase UUID string)",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Store tag, e.g. \"history\", \"kv\"",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Record index to start from; omitted means from the beginning",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "uint64",
              "nullable": true,
              "minimum": 0
            }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Maximum number of records to return",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A batch of records (bare JSON array)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RecordEncrypted"
                  }
                }
              }
            }
          },
          "4XX": {
            "description": "Not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "session": []
          }
        ]
      }
    },
    "/api/v0/store": {
      "delete": {
        "tags": [
          "handlers::v0::store"
        ],
        "operationId": "delete_store",
        "responses": {
          "200": {
            "description": "Store deleted (empty body)"
          },
          "4XX": {
            "description": "Not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "session": []
          }
        ]
      }
    },
    "/healthz": {
      "get": {
        "tags": [
          "handlers::health"
        ],
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": [
          "handlers::user"
        ],
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Logged in; returns a session token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/register": {
      "post": {
        "tags": [
          "handlers::user"
        ],
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Registered; returns a session token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Registration rejected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/{username}": {
      "get": {
        "tags": [
          "handlers::user"
        ],
        "operationId": "get_user",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "description": "Username to look up",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "User not found or request rejected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChangePasswordRequest": {
        "type": "object",
        "required": [
          "current_password",
          "new_password"
        ],
        "properties": {
          "current_password": {
            "type": "string"
          },
          "new_password": {
            "type": "string"
          }
        }
      },
      "ChangePasswordResponse": {
        "type": "object"
      },
      "DeleteUserResponse": {
        "type": "object"
      },
      "EncryptedData": {
        "type": "object",
        "required": [
          "data",
          "content_encryption_key"
        ],
        "properties": {
          "content_encryption_key": {
            "type": "string"
          },
          "data": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "reason"
        ],
        "properties": {
          "reason": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "Host": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "IndexResponse": {
        "type": "object",
        "required": [
          "homage",
          "version"
        ],
        "properties": {
          "homage": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "password": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": [
          "session"
        ],
        "properties": {
          "auth": {
            "type": "string",
            "description": "Auth type: \"hub\" for Hub API tokens, \"cli\" for legacy CLI session tokens.\nOld servers that don't return this field will deserialize as None.",
            "nullable": true
          },
          "session": {
            "type": "string"
          }
        }
      },
      "MeResponse": {
        "type": "object",
        "required": [
          "username"
        ],
        "properties": {
          "username": {
            "type": "string"
          }
        }
      },
      "RecordEncrypted": {
        "type": "object",
        "description": "A single record stored inside of our local database",
        "required": [
          "id",
          "idx",
          "host",
          "timestamp",
          "version",
          "tag",
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/EncryptedData"
          },
          "host": {
            "$ref": "#/components/schemas/Host"
          },
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "a unique ID"
          },
          "idx": {
            "type": "integer",
            "format": "uint64",
            "description": "The integer record ID. This is only unique per (host, tag).",
            "minimum": 0
          },
          "tag": {
            "type": "string",
            "description": "The type of data we are storing here. Eg, \"history\""
          },
          "timestamp": {
            "type": "integer",
            "format": "uint64",
            "description": "The creation time in nanoseconds since unix epoch",
            "minimum": 0
          },
          "version": {
            "type": "string",
            "description": "The version the data in the entry conforms to"
          }
        }
      },
      "RecordStatus": {
        "type": "object",
        "description": "An index representing the current state of the record stores\nThis can be both remote, or local, and compared in either direction",
        "required": [
          "hosts"
        ],
        "properties": {
          "hosts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "format": "uint64",
                "minimum": 0
              }
            }
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "email",
          "username",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "required": [
          "session"
        ],
        "properties": {
          "auth": {
            "type": "string",
            "description": "Auth type: \"hub\" for Hub API tokens, \"cli\" for legacy CLI session tokens.\nOld servers that don't return this field will deserialize as None.",
            "nullable": true
          },
          "session": {
            "type": "string"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "required": [
          "username"
        ],
        "properties": {
          "username": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "session": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Session token presented as `Authorization: Token <session-token>`. This server accepts only the `Token` scheme (exactly one space separator); any other scheme is rejected with 400 {\"reason\":\"invalid authorization header encoding\"}. The full header value including the `Token ` prefix must be supplied."
      }
    }
  }
}
